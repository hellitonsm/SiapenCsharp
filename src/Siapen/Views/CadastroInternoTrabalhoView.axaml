<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Siapen.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="950" d:DesignHeight="650"
        x:Class="Siapen.Views.CadastroInternoTrabalhoView"
        x:DataType="vm:CadastroInternoTrabalhoViewModel"
        Title="SIAPEN - Cadastro de Trabalho"
        WindowStartupLocation="CenterScreen"
        Width="950" Height="650"
        Background="#F4F6F8">

  <Design.DataContext>
    <vm:CadastroInternoTrabalhoViewModel/>
  </Design.DataContext>

  <DockPanel>
    <!-- Left sidebar buttons -->
    <Border DockPanel.Dock="Left" Width="110" Background="#2B3A4A">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="2">
          <Button Content="NOVO" Command="{Binding NovoCommand}"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#198754"
                  IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
          <Button Content="EDITAR" Command="{Binding EditarCommand}"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#0D6EFD"
                  IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
          <Button Content="CANCELAR" Command="{Binding CancelarCommand}"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#6C757D"
                  IsEnabled="{Binding CamposHabilitados}"/>
          <Button Content="SALVAR" Command="{Binding SalvarCommand}"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#0D6EFD"
                  IsEnabled="{Binding CamposHabilitados}"/>
          <Button Content="EXCLUIR" Command="{Binding ExcluirCommand}"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#DC3545"
                  IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
          <Button Content="FECHAR" Click="Fechar_Click"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#DC3545"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Spacing="1" Margin="2,0,2,4">
          <Border Background="#1A2332" CornerRadius="4" Padding="4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
              <Button Content="◀◀" Command="{Binding NavegarPrimeiroCommand}" Width="22" Height="22"
                      FontSize="10" Padding="0"
                      IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
              <Button Content="◀" Command="{Binding NavegarAnteriorCommand}" Width="22" Height="22"
                      FontSize="10" Padding="0"
                      IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
              <Button Content="▶" Command="{Binding NavegarProximoCommand}" Width="22" Height="22"
                      FontSize="10" Padding="0"
                      IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
              <Button Content="▶▶" Command="{Binding NavegarUltimoCommand}" Width="22" Height="22"
                      FontSize="10" Padding="0"
                      IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Width="98" Height="90" Margin="4,0,4,8"
                Background="#343A40" CornerRadius="4">
          <TextBlock Text="[FOTO]" Foreground="#6C757D" FontSize="10"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
      </DockPanel>
    </Border>

    <!-- Main content -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <Border Grid.Row="0" Background="#FFF8F0E0" Height="36" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1">
        <TextBlock Text="SIAPEN - Cadastro de Trabalho"
                   FontSize="15" FontWeight="Bold" Foreground="#2B3A4A"
                   VerticalAlignment="Center" Margin="12,0"/>
      </Border>

      <!-- TabControl -->
      <TabControl Grid.Row="1" SelectedIndex="{Binding TabIndex}" Margin="0"
                  TabStripPlacement="Top">

        <!-- Aba Identificação -->
        <TabItem Header="Identificação">
          <ScrollViewer>
            <Grid Margin="8" ColumnDefinitions="Auto,*,Auto,*"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

              <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding IdInterno}" IsReadOnly="True"
                       Width="80" Height="24" FontSize="12" Margin="4"/>
              <TextBlock Grid.Row="0" Grid.Column="2" Text="Nome" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding NomeInterno}" IsReadOnly="True"
                       Height="24" FontSize="12" Margin="4"/>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="RGI" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Rgi}" IsReadOnly="True"
                       Width="120" Height="24" FontSize="12" Margin="4"/>
              <TextBlock Grid.Row="1" Grid.Column="2" Text="Vulgo" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Vulgo}" IsReadOnly="True"
                       Width="150" Height="24" FontSize="12" Margin="4"/>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Status" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Status}" IsReadOnly="True"
                       Width="40" Height="24" FontSize="12" Margin="4"/>
              <TextBlock Grid.Row="2" Grid.Column="2" Text="Sexo" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding Sexo}" IsReadOnly="True"
                       Width="40" Height="24" FontSize="12" Margin="4"/>

              <TextBlock Grid.Row="3" Grid.Column="0" Text="Unidade Penal" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding NomeUp}" IsReadOnly="True"
                       Height="24" FontSize="12" Margin="4"/>

              <TextBlock Grid.Row="4" Grid.Column="0" Text="Pavilhão" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Pavilhao}" IsReadOnly="True"
                       Height="24" FontSize="12" Margin="4"/>
              <TextBlock Grid.Row="4" Grid.Column="2" Text="Galeria" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding Galeria}" IsReadOnly="True"
                       Height="24" FontSize="12" Margin="4"/>

              <TextBlock Grid.Row="5" Grid.Column="0" Text="Solário" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Solario}" IsReadOnly="True"
                       Height="24" FontSize="12" Margin="4"/>
              <TextBlock Grid.Row="5" Grid.Column="2" Text="Cela" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding Cela}" IsReadOnly="True"
                       Height="24" FontSize="12" Margin="4"/>
            </Grid>
          </ScrollViewer>
        </TabItem>

        <!-- Aba Trabalho -->
        <TabItem Header="Trabalho">
          <TabControl SelectedIndex="{Binding TabTrabalhoIndex}" Margin="0">

            <!-- Sub-aba Lançamento -->
            <TabItem Header="Lançamento">
              <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="8" ColumnDefinitions="Auto,*,Auto,*"
                      RowDefinitions="Auto,Auto,Auto,Auto">

                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Nº Documento" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DocTrabalho}"
                           Width="120" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>
                  <TextBlock Grid.Row="0" Grid.Column="2" Text="Data" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding DataSetor}" Margin="4" Height="24"
                              IsEnabled="{Binding CamposHabilitados}"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Função Interno" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <Grid Grid.Row="1" Grid.Column="1" Margin="4" ColumnDefinitions="*,Auto">
                    <ComboBox Grid.Column="0" ItemsSource="{Binding FuncoesInterno}"
                              SelectedItem="{Binding SelectedFuncaoInterno}"
                              DisplayMemberBinding="{Binding DisplayName}"
                              Height="24" FontSize="12"
                              IsEnabled="{Binding CamposHabilitados}"/>
                    <Button Grid.Column="1" Content="..." Width="24" Height="24" Padding="0" Margin="4,0,0,0"
                            IsEnabled="{Binding CamposHabilitados}"/>
                  </Grid>
                  <TextBlock Grid.Row="1" Grid.Column="2" Text="Local Trabalho" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <Grid Grid.Row="1" Grid.Column="3" Margin="4" ColumnDefinitions="*,Auto">
                    <ComboBox Grid.Column="0" ItemsSource="{Binding LocaisTrabalho}"
                              SelectedItem="{Binding SelectedLocalTrabalho}"
                              DisplayMemberBinding="{Binding DisplayName}"
                              Height="24" FontSize="12"
                              IsEnabled="{Binding CamposHabilitados}"/>
                    <Button Grid.Column="1" Content="..." Width="24" Height="24" Padding="0" Margin="4,0,0,0"
                            IsEnabled="{Binding CamposHabilitados}"/>
                  </Grid>

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Setor Trabalho" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <Grid Grid.Row="2" Grid.Column="1" Margin="4" ColumnDefinitions="*,Auto">
                    <ComboBox Grid.Column="0" ItemsSource="{Binding SetoresTrabalho}"
                              SelectedItem="{Binding SelectedSetorTrabalho}"
                              DisplayMemberBinding="{Binding DisplayName}"
                              Height="24" FontSize="12"
                              IsEnabled="{Binding CamposHabilitados}"/>
                    <Button Grid.Column="1" Content="..." Width="24" Height="24" Padding="0" Margin="4,0,0,0"
                            IsEnabled="{Binding CamposHabilitados}"/>
                  </Grid>
                  <TextBlock Grid.Row="2" Grid.Column="2" Text="Tipo Atividade" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <ComboBox Grid.Row="2" Grid.Column="3" SelectedValue="{Binding TipoAtividade}"
                            IsEnabled="{Binding CamposHabilitados}" Height="24" Margin="4">
                    <ComboBoxItem Content="INTERNA"/>
                    <ComboBoxItem Content="EXTERNA"/>
                  </ComboBox>

                  <TextBlock Grid.Row="3" Grid.Column="0" Text="OBS" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding ObsTrabalho}"
                           Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>
                </Grid>

                <!-- Grid histórico trabalho -->
                <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="1" Margin="4">
                  <DataGrid ItemsSource="{Binding HistoricoTrabalhoItems}"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            GridLinesVisibility="Horizontal"
                            BorderThickness="0" Background="White"
                            RowHeight="28" FontSize="12"
                            x:CompileBindings="False">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="90"/>
                      <DataGridTextColumn Header="Data Trabalho" Binding="{Binding Data}" Width="100"/>
                      <DataGridTextColumn Header="Local Trabalho" Binding="{Binding LocalTrabalho}" Width="140"/>
                      <DataGridTextColumn Header="Setor Trabalho" Binding="{Binding SetorTrabalho}" Width="120"/>
                      <DataGridTextColumn Header="Função" Binding="{Binding Funcao}" Width="110"/>
                      <DataGridTextColumn Header="OBS" Binding="{Binding Obs}" Width="*"/>
                      <DataGridTextColumn Header="Data Saída" Binding="{Binding DataSaida}" Width="100"/>
                      <DataGridTextColumn Header="Motivo Saída" Binding="{Binding MotivoSaida}" Width="130"/>
                    </DataGrid.Columns>
                  </DataGrid>
                </Border>
              </DockPanel>
            </TabItem>

            <!-- Sub-aba Horários -->
            <TabItem Header="Horários">
              <ScrollViewer>
                <Grid Margin="8" ColumnDefinitions="Auto,*,Auto,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

                  <!-- Saidão -->
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Horário Saída Saída" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding HorarioSaidaSaidao}"
                           Width="120" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>
                  <TextBlock Grid.Row="0" Grid.Column="2" Text="Horário Entrada Saída" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding HorarioEntradaSaidao}"
                           Width="120" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Turma Saída" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TurmaSaidao}"
                           Width="80" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>
                  <TextBlock Grid.Row="1" Grid.Column="2" Text="Corte" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Corte}"
                           Width="80" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>

                  <!-- Semanal -->
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Horário Saída Semanal" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding HorarioSaidaSemanal}"
                           Width="120" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>
                  <TextBlock Grid.Row="2" Grid.Column="2" Text="Horário Entrada Semanal" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding HorarioEntradaSemanal}"
                           Width="120" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>

                  <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="4">
                    <Button Content="Copiar para todos" Width="130" Height="26" FontSize="11"
                            IsEnabled="{Binding CamposHabilitados}"/>
                  </Grid>

                  <!-- Sábado -->
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="Horário Saída Sábado" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding HorarioSaidaSabado}"
                           Width="120" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>
                  <TextBlock Grid.Row="4" Grid.Column="2" Text="Horário Entrada Sábado" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding HorarioEntradaSabado}"
                           Width="120" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>

                  <!-- Domingo -->
                  <TextBlock Grid.Row="5" Grid.Column="0" Text="Horário Saída Domingo" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding HorarioSaidaDomingo}"
                           Width="120" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>
                  <TextBlock Grid.Row="5" Grid.Column="2" Text="Horário Entrada Domingo" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                  <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding HorarioEntradaDomingo}"
                           Width="120" Height="24" FontSize="12" Margin="4"
                           IsEnabled="{Binding CamposHabilitados}"/>

                  <!-- GroupBox dias de folga -->
                  <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="4" Margin="4,12,4,4"
                          BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="4" Padding="8">
                    <StackPanel>
                      <TextBlock Text="Para dias de folga deixe em branco:" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                      <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*"
                            RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Saída Segunda" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding HorarioSaidaSeg}"
                                 Width="100" Height="24" FontSize="12" Margin="4"
                                 IsEnabled="{Binding CamposHabilitados}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Entrada Segunda" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding HorarioEntradaSeg}"
                                 Width="100" Height="24" FontSize="12" Margin="4"
                                 IsEnabled="{Binding CamposHabilitados}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Saída Terça" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding HorarioSaidaTer}"
                                 Width="100" Height="24" FontSize="12" Margin="4"
                                 IsEnabled="{Binding CamposHabilitados}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Entrada Terça" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding HorarioEntradaTer}"
                                 Width="100" Height="24" FontSize="12" Margin="4"
                                 IsEnabled="{Binding CamposHabilitados}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Saída Quarta" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding HorarioSaidaQua}"
                                 Width="100" Height="24" FontSize="12" Margin="4"
                                 IsEnabled="{Binding CamposHabilitados}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Entrada Quarta" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding HorarioEntradaQua}"
                                 Width="100" Height="24" FontSize="12" Margin="4"
                                 IsEnabled="{Binding CamposHabilitados}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Saída Quinta" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding HorarioSaidaQui}"
                                 Width="100" Height="24" FontSize="12" Margin="4"
                                 IsEnabled="{Binding CamposHabilitados}"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Entrada Quinta" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding HorarioEntradaQui}"
                                 Width="100" Height="24" FontSize="12" Margin="4"
                                 IsEnabled="{Binding CamposHabilitados}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Saída Sexta" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding HorarioSaidaSex}"
                                 Width="100" Height="24" FontSize="12" Margin="4"
                                 IsEnabled="{Binding CamposHabilitados}"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="Entrada Sexta" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding HorarioEntradaSex}"
                                 Width="100" Height="24" FontSize="12" Margin="4"
                                 IsEnabled="{Binding CamposHabilitados}"/>
                      </Grid>
                    </StackPanel>
                  </Border>
                </Grid>
              </ScrollViewer>
            </TabItem>

            <!-- Sub-aba Remição -->
            <TabItem Header="Remição">
              <TabControl SelectedIndex="{Binding TabRemicaoIndex}" Margin="0">

                <!-- Sub-sub-aba Dados -->
                <TabItem Header="Dados">
                  <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="8" ColumnDefinitions="Auto,*,Auto,*,Auto,*"
                          RowDefinitions="Auto,Auto,Auto">

                      <TextBlock Grid.Row="0" Grid.Column="0" Text="Data Inicial" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                      <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding RemicaoDataInicial}" Margin="4" Height="24"
                                  IsEnabled="{Binding CamposHabilitados}"/>
                      <TextBlock Grid.Row="0" Grid.Column="2" Text="Data Final" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                      <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding RemicaoDataFinal}" Margin="4" Height="24"
                                  IsEnabled="{Binding CamposHabilitados}"/>

                      <TextBlock Grid.Row="1" Grid.Column="0" Text="Dias Trabalho" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                      <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RemicaoDiasTrabalhado}"
                               Width="80" Height="24" FontSize="12" Margin="4"
                               IsEnabled="{Binding CamposHabilitados}"/>

                      <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="4">
                        <Button Content="Calcular" Width="80" Height="26" FontSize="11" Margin="0,0,8,0"
                                IsEnabled="{Binding CamposHabilitados}"/>
                        <Button Content="Inserir" Width="80" Height="26" FontSize="11"
                                IsEnabled="{Binding CamposHabilitados}"/>
                      </StackPanel>
                    </Grid>

                    <!-- Grid remissões -->
                    <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="1" Margin="4">
                      <DataGrid ItemsSource="{Binding RemicaoItems}"
                                AutoGenerateColumns="False"
                                IsReadOnly="True"
                                GridLinesVisibility="Horizontal"
                                BorderThickness="0" Background="White"
                                RowHeight="28" FontSize="12"
                                x:CompileBindings="False">
                        <DataGrid.Columns>
                          <DataGridTextColumn Header="Data Inicial" Binding="{Binding DataInicial}" Width="120"/>
                          <DataGridTextColumn Header="Data Final" Binding="{Binding DataFinal}" Width="120"/>
                          <DataGridTextColumn Header="Dias Trabalhado" Binding="{Binding DiasTrabalhado}" Width="*"/>
                        </DataGrid.Columns>
                      </DataGrid>
                    </Border>
                  </DockPanel>
                </TabItem>

                <!-- Sub-sub-aba Certidão -->
                <TabItem Header="Certidão">
                  <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="8" ColumnDefinitions="Auto,*,Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                      <TextBlock Grid.Row="0" Grid.Column="0" Text="Data Inicial" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                      <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding CertidaoDataInicial}" Margin="4" Height="24"
                                  IsEnabled="{Binding CamposHabilitados}"/>
                      <TextBlock Grid.Row="0" Grid.Column="2" Text="Data Final" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                      <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding CertidaoDataFinal}" Margin="4" Height="24"
                                  IsEnabled="{Binding CamposHabilitados}"/>

                      <TextBlock Grid.Row="1" Grid.Column="0" Text="Saldo Anterior" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                      <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CertidaoSaldoAnterior}"
                               Width="80" Height="24" FontSize="12" Margin="4"
                               IsEnabled="{Binding CamposHabilitados}"/>
                      <TextBlock Grid.Row="1" Grid.Column="2" Text="Dias Trabalhado" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                      <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding CertidaoDiasTrabalhado}"
                               Width="80" Height="24" FontSize="12" Margin="4"
                               IsEnabled="{Binding CamposHabilitados}"/>

                      <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Trabalhado" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                      <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CertidaoTotalTrabalhado}"
                               Width="80" Height="24" FontSize="12" Margin="4"
                               IsEnabled="{Binding CamposHabilitados}"/>
                      <TextBlock Grid.Row="2" Grid.Column="2" Text="Dias Remido" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                      <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding CertidaoDiasRemido}"
                               Width="80" Height="24" FontSize="12" Margin="4"
                               IsEnabled="{Binding CamposHabilitados}"/>

                      <TextBlock Grid.Row="3" Grid.Column="0" Text="Saldo Próxima" FontSize="12" VerticalAlignment="Center" Margin="4"/>
                      <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CertidaoSaldoProxima}"
                               Width="80" Height="24" FontSize="12" Margin="4"
                               IsEnabled="{Binding CamposHabilitados}"/>

                      <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="4">
                        <Button Content="Calcular" Width="80" Height="26" FontSize="11" Margin="0,0,8,0"
                                IsEnabled="{Binding CamposHabilitados}"/>
                        <Button Content="Inserir" Width="80" Height="26" FontSize="11"
                                IsEnabled="{Binding CamposHabilitados}"/>
                      </StackPanel>
                    </Grid>

                    <!-- Grid certidões -->
                    <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="1" Margin="4">
                      <DataGrid ItemsSource="{Binding CertidaoItems}"
                                AutoGenerateColumns="False"
                                IsReadOnly="True"
                                GridLinesVisibility="Horizontal"
                                BorderThickness="0" Background="White"
                                RowHeight="28" FontSize="12"
                                x:CompileBindings="False">
                        <DataGrid.Columns>
                          <DataGridTextColumn Header="Data Inicial" Binding="{Binding DataInicial}" Width="90"/>
                          <DataGridTextColumn Header="Data Final" Binding="{Binding DataFinal}" Width="90"/>
                          <DataGridTextColumn Header="Saldo Anterior" Binding="{Binding SaldoAnterior}" Width="100"/>
                          <DataGridTextColumn Header="Dias Trabalhado" Binding="{Binding DiasTrabalhado}" Width="110"/>
                          <DataGridTextColumn Header="Total Trabalho" Binding="{Binding TotalDias}" Width="100"/>
                          <DataGridTextColumn Header="Dias Remido" Binding="{Binding DiasRemido}" Width="90"/>
                          <DataGridTextColumn Header="Saldo Próxima" Binding="{Binding SaldoProxima}" Width="*"/>
                        </DataGrid.Columns>
                      </DataGrid>
                    </Border>
                  </DockPanel>
                </TabItem>
              </TabControl>
            </TabItem>
          </TabControl>
        </TabItem>

        <!-- Aba Histórico -->
        <TabItem Header="Histórico">
          <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="8" ColumnDefinitions="Auto,*,Auto"
                  RowDefinitions="Auto,Auto">

              <TextBlock Grid.Row="0" Grid.Column="0" Text="Data" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding HistoricoData}" Margin="4" Height="24"
                          IsEnabled="{Binding CamposHabilitados}"/>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Descrição" FontSize="12" VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding HistoricoDescricao}"
                       Height="60" FontSize="12" Margin="4"
                       IsEnabled="{Binding CamposHabilitados}"
                       AcceptsReturn="True" TextWrapping="Wrap"/>
              <Button Grid.Row="1" Grid.Column="2" Content="Incluir" Width="80" Height="26" FontSize="11"
                      VerticalAlignment="Bottom" Margin="4"
                      IsEnabled="{Binding CamposHabilitados}"/>
            </Grid>

            <!-- Grid histórico interno -->
            <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="1" Margin="4">
              <DataGrid ItemsSource="{Binding HistoricoInternoItems}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        GridLinesVisibility="Horizontal"
                        BorderThickness="0" Background="White"
                        RowHeight="28" FontSize="12"
                        x:CompileBindings="False">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Data" Binding="{Binding DataHora}" Width="120"/>
                  <DataGridTextColumn Header="Setor" Binding="{Binding Setor}" Width="100"/>
                  <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="*"/>
                </DataGrid.Columns>
              </DataGrid>
            </Border>
          </DockPanel>
        </TabItem>

        <!-- Aba Consulta -->
        <TabItem Header="Consulta">
          <DockPanel>
            <Border DockPanel.Dock="Top" Background="#F8F9FA" Padding="8" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Localizar:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#2B3A4A" FontSize="13"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText}" PlaceholderText="Digite para filtrar..."
                         FontSize="14" Height="30" Width="250" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="2" Text="Filtro:" VerticalAlignment="Center" Margin="12,0,4,0"
                           Foreground="#2B3A4A" FontSize="12"/>
                <RadioButton Grid.Column="3" Content="Ativo" Margin="0,0,8,0" FontSize="12"
                             IsChecked="{Binding FiltroAtivo}"/>
                <RadioButton Grid.Column="4" Content="Inativo" FontSize="12"
                             IsChecked="{Binding FiltroInativo}"/>
              </Grid>
            </Border>

            <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0">
              <DataGrid ItemsSource="{Binding GridItems}"
                        SelectedItem="{Binding SelectedGridItem}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        GridLinesVisibility="Horizontal"
                        BorderThickness="0" Background="White"
                        RowHeight="28" FontSize="12"
                        x:CompileBindings="False"
                        DoubleTapped="DataGrid_DoubleTapped">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Nome do Interno" Binding="{Binding NomeInterno}" Width="*"/>
                  <DataGridTextColumn Header="RGI" Binding="{Binding Rgi}" Width="80"/>
                  <DataGridTextColumn Header="Vulgo" Binding="{Binding Vulgo}" Width="120"/>
                  <DataGridTextColumn Header="Sigla" Binding="{Binding Sigla}" Width="60"/>
                  <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="60"/>
                </DataGrid.Columns>
              </DataGrid>
            </Border>
          </DockPanel>
        </TabItem>
      </TabControl>

      <!-- Status bar -->
      <Border Grid.Row="2" Background="#212529" Padding="8,4" Height="26">
        <TextBlock Text="{Binding StatusMessage}" Foreground="#20C997" FontSize="12"/>
      </Border>
    </Grid>
  </DockPanel>
</Window>
