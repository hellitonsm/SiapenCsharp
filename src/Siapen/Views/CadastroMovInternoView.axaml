<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Siapen.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="950" d:DesignHeight="650"
        x:Class="Siapen.Views.CadastroMovInternoView"
        x:DataType="vm:CadastroMovInternoViewModel"
        Title="SIAPEN - Cadastro Movimentação do Interno(a)"
        WindowStartupLocation="CenterScreen"
        Width="950" Height="650"
        Background="#F4F6F8">

  <Design.DataContext>
    <vm:CadastroMovInternoViewModel/>
  </Design.DataContext>

  <DockPanel>
    <!-- Left sidebar buttons -->
    <Border DockPanel.Dock="Left" Width="110" Background="#2B3A4A">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="2">
          <Button Content="NOVO" Command="{Binding NovoCommand}"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#198754"
                  IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
          <Button Content="EDITAR" Command="{Binding EditarCommand}"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#0D6EFD"
                  IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
          <Button Content="CANCELAR" Command="{Binding CancelarCommand}"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#6C757D"
                  IsEnabled="{Binding CamposHabilitados}"/>
          <Button Content="SALVAR" Command="{Binding SalvarCommand}"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#0D6EFD"
                  IsEnabled="{Binding CamposHabilitados}"/>
          <Button Content="EXCLUIR" Command="{Binding ExcluirCommand}"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#DC3545"
                  IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
          <Button Content="FECHAR" Click="Fechar_Click"
                  Height="34" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#DC3545"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Spacing="1" Margin="2,0,2,4">
          <Border Background="#1A2332" CornerRadius="4" Padding="4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
              <Button Content="◀◀" Command="{Binding NavegarPrimeiroCommand}" Width="22" Height="22"
                      FontSize="10" Padding="0"
                      IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
              <Button Content="◀" Command="{Binding NavegarAnteriorCommand}" Width="22" Height="22"
                      FontSize="10" Padding="0"
                      IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
              <Button Content="▶" Command="{Binding NavegarProximoCommand}" Width="22" Height="22"
                      FontSize="10" Padding="0"
                      IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
              <Button Content="▶▶" Command="{Binding NavegarUltimoCommand}" Width="22" Height="22"
                      FontSize="10" Padding="0"
                      IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Width="98" Height="90" Margin="4,0,4,8"
                Background="#343A40" CornerRadius="4">
          <TextBlock Text="[FOTO]" Foreground="#6C757D" FontSize="10"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
      </DockPanel>
    </Border>

    <!-- Main content -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <Border Grid.Row="0" Background="#FFF8F0E0" Height="36" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1">
        <TextBlock Text="SIAPEN - Cadastro Movimentação do Interno(a)"
                   FontSize="15" FontWeight="Bold" Foreground="#2B3A4A"
                   VerticalAlignment="Center" Margin="12,0"/>
      </Border>

      <!-- TabControl -->
      <TabControl Grid.Row="1" SelectedIndex="{Binding TabIndex}" Margin="0"
                  TabStripPlacement="Top">

        <!-- Aba Cadastro -->
        <TabItem Header="Cadastro">
          <ScrollViewer>
            <Grid Margin="8" ColumnDefinitions="Auto,*,Auto,*"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

              <!-- Row 0: ID + Interno -->
              <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" FontSize="12"
                         VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding IdMovInterno}"
                       IsReadOnly="True" Width="80" Height="24" FontSize="12" Margin="4"/>

              <TextBlock Grid.Row="0" Grid.Column="2" Text="Interno" FontSize="12"
                         VerticalAlignment="Center" Margin="4"/>
              <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding Internos}"
                        SelectedItem="{Binding SelectedInterno}"
                        DisplayMemberBinding="{Binding DisplayName}"
                        Height="24" FontSize="12" Margin="4"
                        IsEnabled="{Binding CamposHabilitados}"/>

              <!-- Row 1: Unidade Penal -->
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Unidade Penal" FontSize="12"
                         VerticalAlignment="Center" Margin="4"/>
              <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                        ItemsSource="{Binding UnidadesPenal}"
                        SelectedItem="{Binding SelectedUnidadePenal}"
                        DisplayMemberBinding="{Binding DisplayName}"
                        Height="24" FontSize="12" Margin="4"
                        IsEnabled="{Binding CamposHabilitados}"/>

              <!-- Row 2: Data + Hora -->
              <TextBlock Grid.Row="2" Grid.Column="0" Text="Data Movimentação" FontSize="12"
                         VerticalAlignment="Center" Margin="4"/>
              <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding DataMovimentacao}"
                          Margin="4" Height="24"
                          IsEnabled="{Binding CamposHabilitados}"/>

              <TextBlock Grid.Row="2" Grid.Column="2" Text="Hora Movimentação" FontSize="12"
                         VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding HoraMovimentacao}"
                       PlaceholderText="HH:MM" Height="24" FontSize="12" Margin="4"
                       IsEnabled="{Binding CamposHabilitados}"/>

              <!-- Row 3: Tipo Movimentação -->
              <TextBlock Grid.Row="3" Grid.Column="0" Text="Tipo Movimentação" FontSize="12"
                         VerticalAlignment="Center" Margin="4"/>
              <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                       Text="{Binding TipoMovimentacao}"
                       Height="24" FontSize="12" Margin="4"
                       IsEnabled="{Binding CamposHabilitados}"/>

              <!-- Row 4: Servidor -->
              <TextBlock Grid.Row="4" Grid.Column="0" Text="Servidor" FontSize="12"
                         VerticalAlignment="Center" Margin="4"/>
              <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                        ItemsSource="{Binding Funcionarios}"
                        SelectedItem="{Binding SelectedFuncionario}"
                        DisplayMemberBinding="{Binding DisplayName}"
                        Height="24" FontSize="12" Margin="4"
                        IsEnabled="{Binding CamposHabilitados}"/>

              <!-- Row 5: Procedência + Destino -->
              <TextBlock Grid.Row="5" Grid.Column="0" Text="Procedência" FontSize="12"
                         VerticalAlignment="Center" Margin="4"/>
              <ComboBox Grid.Row="5" Grid.Column="1"
                        ItemsSource="{Binding Procedencias}"
                        SelectedItem="{Binding SelectedProcedencia}"
                        DisplayMemberBinding="{Binding DisplayName}"
                        Height="24" FontSize="12" Margin="4"
                        IsEnabled="{Binding CamposHabilitados}"/>

              <TextBlock Grid.Row="5" Grid.Column="2" Text="Destino" FontSize="12"
                         VerticalAlignment="Center" Margin="4"/>
              <ComboBox Grid.Row="5" Grid.Column="3"
                        ItemsSource="{Binding Destinos}"
                        SelectedItem="{Binding SelectedDestino}"
                        DisplayMemberBinding="{Binding DisplayName}"
                        Height="24" FontSize="12" Margin="4"
                        IsEnabled="{Binding CamposHabilitados}"/>

            </Grid>
          </ScrollViewer>
        </TabItem>

        <!-- Aba Consulta -->
        <TabItem Header="Consulta">
          <DockPanel>
            <Border DockPanel.Dock="Top" Background="#F8F9FA" Padding="8"
                    BorderBrush="#DEE2E6" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="Localizar:" VerticalAlignment="Center"
                           Margin="0,0,8,0" Foreground="#2B3A4A" FontSize="13"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText}"
                         PlaceholderText="Digite para filtrar por nome do interno..."
                         FontSize="14" Height="30"/>
              </Grid>
            </Border>

            <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0">
              <DataGrid ItemsSource="{Binding GridItems}"
                        SelectedItem="{Binding SelectedGridItem}"
                        AutoGenerateColumns="True"
                        IsReadOnly="True"
                        GridLinesVisibility="Horizontal"
                        BorderThickness="0" Background="White"
                        RowHeight="28" FontSize="12"
                        DoubleTapped="DataGrid_DoubleTapped">
              </DataGrid>
            </Border>
          </DockPanel>
        </TabItem>
      </TabControl>

      <!-- Status bar -->
      <Border Grid.Row="2" Background="#212529" Padding="8,4" Height="26">
        <TextBlock Text="{Binding StatusMessage}" Foreground="#20C997" FontSize="12"/>
      </Border>
    </Grid>
  </DockPanel>
</Window>
