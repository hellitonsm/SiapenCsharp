<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Siapen.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="600"
        x:Class="Siapen.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="SIAPEN - Login"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Width="450" Height="600"
        Background="#F4F6F8">

  <Design.DataContext>
    <vm:LoginViewModel/>
  </Design.DataContext>

  <Grid>
    <!-- Card centralizado -->
    <Border Classes="card" HorizontalAlignment="Center" VerticalAlignment="Center" Width="360" Margin="16">
      <StackPanel Spacing="16">
        
        <!-- Cabeçalho -->
        <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,16">
          <Border Width="64" Height="64" CornerRadius="32" Background="#E9ECEF" HorizontalAlignment="Center" Margin="0,0,0,8">
            <TextBlock Text="🛡" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="SIAPEN" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#212529"/>
          <TextBlock Text="Agência Estadual de Administração do Sistema Penitenciário" 
                     FontSize="12" Foreground="#6C757D" TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>

        <!-- Formulário -->
        <StackPanel Spacing="14">
          <StackPanel Spacing="4">
            <TextBlock Text="Usuário" FontWeight="SemiBold" FontSize="13" Foreground="#495057"/>
            <TextBox x:Name="TxtLogin" Text="{Binding Login}" PlaceholderText="Digite seu usuário" Height="40" FontSize="14"/>
          </StackPanel>
          
          <StackPanel Spacing="4">
            <TextBlock Text="Senha" FontWeight="SemiBold" FontSize="13" Foreground="#495057"/>
            <TextBox Text="{Binding Senha}" PlaceholderText="Digite sua senha" PasswordChar="•" Height="40" FontSize="14"/>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="Unidade Penal" FontWeight="SemiBold" FontSize="13" Foreground="#495057"/>
            <ComboBox x:Name="ComboUp" PlaceholderText="Selecione a Unidade..." 
                      ItemsSource="{Binding UnidadesPenal}" SelectedItem="{Binding SelectedUp}"
                      HorizontalAlignment="Stretch" Height="40" FontSize="14">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding NomeUp}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </StackPanel>

        <!-- Ações -->
        <StackPanel Spacing="8" Margin="0,24,0,0">
          <Button Classes="primary" Content="Entrar" Command="{Binding EntrarCommand}" 
                  IsEnabled="{Binding PodeEntrar}" HorizontalAlignment="Stretch" Height="44" FontSize="14"/>
          <Button Content="Sair" Command="{Binding SairCommand}" 
                  HorizontalAlignment="Stretch" Height="40" Background="Transparent" BorderThickness="0" Foreground="#6C757D" FontSize="14"/>
        </StackPanel>

        <!-- Status -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,8,0,0">
          <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="4" Width="200" Margin="0,0,0,8" Foreground="#0d6efd"/>
          <TextBlock Text="Conectando ao banco..." FontSize="12" Foreground="#6C757D" FontStyle="Italic" 
                     HorizontalAlignment="Center" IsVisible="{Binding IsConnecting}"/>
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC3545" FontSize="12" TextWrapping="Wrap" 
                     HorizontalAlignment="Center" TextAlignment="Center"
                     IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</Window>
