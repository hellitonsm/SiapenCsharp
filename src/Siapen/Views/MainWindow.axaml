<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Siapen.ViewModels"
        xmlns:models="using:Siapen.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Siapen.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SIAPEN - Sistema Integrado de Administração Penitenciária"
        WindowState="Maximized"
        Background="#F4F6F8">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <DockPanel>
    <!-- Menu Principal -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="Cadastro">
        <MenuItem Header="Pavilhão" Command="{Binding CadastroPavilhaoCommand}"/>
        <MenuItem Header="Galeria" Command="{Binding CadastroGaleriaCommand}"/>
        <MenuItem Header="Solário" Command="{Binding CadastroSolarioCommand}"/>
        <MenuItem Header="Cela" Command="{Binding CadastroCelaCommand}"/>
        <Separator/>
        <MenuItem Header="Internos" Command="{Binding CadastroInternosCommand}"/>
        <MenuItem Header="Condição do Interno" Command="{Binding CadastroCondicaoInternoCommand}"/>
        <Separator/>
        <MenuItem Header="Advogado" Command="{Binding CadastroAdvogadoCommand}"/>
        <MenuItem Header="Facção" Command="{Binding CadastroFaccaoCommand}"/>
        <MenuItem Header="Cidade" Command="{Binding CadastroCidadeCommand}"/>
        <MenuItem Header="Raça" Command="{Binding CadastroRacaCommand}"/>
        <MenuItem Header="Escolaridade" Command="{Binding CadastroEscolaridadeCommand}"/>
        <MenuItem Header="Nacionalidade" Command="{Binding CadastroNacionalidadeCommand}"/>
        <MenuItem Header="Procedência" Command="{Binding CadastroProcedenciaCommand}"/>
        <MenuItem Header="Destino" Command="{Binding CadastroDestinoCommand}"/>
        <MenuItem Header="Fornecedor" Command="{Binding CadastroFornecedorCommand}"/>
        <Separator/>
        <MenuItem Header="Profissão" Command="{Binding CadastroProfissaoCommand}"/>
        <Separator/>
        <MenuItem Header="CTC" Command="{Binding CadastroCtcCommand}"/>
      </MenuItem>

      <MenuItem Header="Movimentação">
        <MenuItem Header="Transferência de Interno (Movimento Externo)" Command="{Binding TransferenciaInternoCommand}"/>
        <Separator/>
        <MenuItem Header="Conferir Transferência Recebida" Command="{Binding ConferirTransferenciaRecebidaCommand}"/>
        <Separator/>
        <MenuItem Header="Mudança de Cela (Movimento Interno)" Command="{Binding MudancaCelaCommand}"/>
        <Separator/>
        <MenuItem Header="Cadastro da Portaria do Saída" Command="{Binding CadastroPortariaSaidaoCommand}"/>
        <MenuItem Header="Inclusão dos Internos no Saída" Command="{Binding InclusaoSaidaoCommand}"/>
        <Separator/>
        <MenuItem Header="Circulação de Interno" Command="{Binding CirculacaoInternoCommand}"/>
        <Separator/>
        <MenuItem Header="Movimento Semi-Aberto / Aberto" Command="{Binding MovimentoSemiAbertoCommand}"/>
        <Separator/>
        <MenuItem Header="Consulta Movimentação Geral do Interno" Command="{Binding ConsultaMovimentacaoGeralCommand}"/>
      </MenuItem>

      <MenuItem Header="Setores">
        <MenuItem Header="Disciplina">
          <MenuItem Header="Disciplina" Command="{Binding DisciplinaCommand}"/>
          <MenuItem Header="Falta Disciplinar" Command="{Binding FaltaDisciplinarCommand}"/>
        </MenuItem>
        <MenuItem Header="Educação">
          <MenuItem Header="Educação" Command="{Binding EducacaoCommand}"/>
          <MenuItem Header="Série/Fase Atual" Command="{Binding SerieFaseAtualCommand}"/>
          <MenuItem Header="Livro/Revista" Command="{Binding LivroRevistaCommand}"/>
          <MenuItem Header="Carga Horária" Command="{Binding CargaHorariaCommand}"/>
        </MenuItem>
        <MenuItem Header="Jurídico">
          <MenuItem Header="Jurídico" Command="{Binding JuridicoCommand}"/>
          <Separator/>
          <MenuItem Header="Processos e/ou Condenações do Interno" Command="{Binding ProcessosCondenacoesCommand}"/>
          <MenuItem Header="Detração / Desconto na pena definitiva aplicada" Command="{Binding DetracaoCommand}"/>
          <MenuItem Header="Interrupções da Execução Penal" Command="{Binding InterrupcoesPenaCommand}"/>
          <MenuItem Header="Remições de Pena" Command="{Binding RemicoesPenaCommand}"/>
          <Separator/>
          <MenuItem Header="Artigos do Código Penal Brasileiro" Command="{Binding ArtigoPenalCommand}"/>
          <Separator/>
          <MenuItem Header="Vara de Execução" Command="{Binding VaraExecucaoCommand}"/>
        </MenuItem>
        <MenuItem Header="Psicossocial" Command="{Binding PsicossocialCommand}"/>
        <MenuItem Header="Reabilitação">
          <MenuItem Header="Pedagogia" Command="{Binding PedagogiaCommand}"/>
          <MenuItem Header="Serviço Social" Command="{Binding ServicoSocialCommand}"/>
          <MenuItem Header="Terapia Ocupacional" Command="{Binding TerapiaOcupacionalCommand}"/>
        </MenuItem>
        <MenuItem Header="Saúde">
          <MenuItem Header="Clínica Médica" Command="{Binding ClinicaMedicaCommand}"/>
          <MenuItem Header="Enfermagem" Command="{Binding EnfermagemCommand}"/>
          <MenuItem Header="Farmácia" Command="{Binding FarmaciaCommand}"/>
          <MenuItem Header="Odontologia" Command="{Binding OdontologiaCommand}"/>
          <MenuItem Header="Psicologia" Command="{Binding PsicologiaCommand}"/>
          <MenuItem Header="Psiquiatria" Command="{Binding PsiquiatriaCommand}"/>
          <Separator/>
          <MenuItem Header="Remédio" Command="{Binding RemedioCommand}"/>
          <MenuItem Header="Saúde" Command="{Binding SaudeCommand}"/>
        </MenuItem>
        <MenuItem Header="Trabalho">
          <MenuItem Header="Trabalho" Command="{Binding TrabalhoCommand}"/>
          <MenuItem Header="Setor Trabalho" Command="{Binding SetorTrabalhoCommand}"/>
          <MenuItem Header="Função Interno" Command="{Binding FuncaoInternoCommand}"/>
          <Separator/>
          <MenuItem Header="Cálculo de Trabalho" Command="{Binding CalculoTrabalhoCommand}"/>
          <MenuItem Header="Remição Trabalho" Command="{Binding RemicaoTrabalhoCommand}"/>
        </MenuItem>
        <MenuItem Header="Plantão">
          <MenuItem Header="Roupas" Command="{Binding RoupasCommand}"/>
          <MenuItem Header="Ocorrências" Command="{Binding OcorrenciasCommand}"/>
        </MenuItem>
        <MenuItem Header="Conselho Disciplinar" Command="{Binding ConselhoDisciplinarCommand}"/>
        <MenuItem Header="Correspondência" Command="{Binding CorrespondenciaCommand}"/>
      </MenuItem>

      <MenuItem Header="Visitantes">
        <MenuItem Header="Entrada de Visitantes" Command="{Binding EntradaVisitantesCommand}"/>
        <Separator/>
        <MenuItem Header="Consulta" Command="{Binding ConsultaVisitanteCommand}"/>
        <MenuItem Header="Grau Parentesco" Command="{Binding GrauParentescoCommand}"/>
        <MenuItem Header="Visitante" Command="{Binding VisitanteCommand}"/>
        <MenuItem Header="Visitantes Tráfico" Command="{Binding VisitantesTraficoCommand}"/>
      </MenuItem>

      <MenuItem Header="Relatórios">
        <MenuItem Header="Menu de Relatórios" Command="{Binding MenuRelatoriosCommand}"/>
        <Separator/>
        <MenuItem Header="Consulta">
          <MenuItem Header="Interno" Command="{Binding ConsultaInternoCommand}"/>
        </MenuItem>
      </MenuItem>

      <MenuItem Header="Módulos">
        <MenuItem Header="Patrimônio">
          <MenuItem Header="Tipo de Patrimônio" Command="{Binding TipoPatrimonioCommand}"/>
          <Separator/>
          <MenuItem Header="Cadastro de Patrimônio" Command="{Binding CadastroPatrimonioCommand}"/>
        </MenuItem>
        <Separator/>
        <MenuItem Header="Módulo Gestão de Armas" Command="{Binding ModuloGestaoArmasCommand}"/>
        <Separator/>
        <MenuItem Header="Controle de Portaria" Command="{Binding ControlePortariaCommand}"/>
        <Separator/>
        <MenuItem Header="Inteligência" Command="{Binding InteligenciaCommand}" IsVisible="False"/>
        <Separator/>
        <MenuItem Header="Monitoramento" Command="{Binding MonitoramentoCommand}"/>
        <Separator/>
        <MenuItem Header="Planilha Dinâmica" Command="{Binding PlanilhaDinamicaCommand}" IsVisible="False"/>
        <Separator/>
        <MenuItem Header="Siapen Messenger" Command="{Binding SiapenMessengerCommand}" IsVisible="False"/>
        <Separator/>
        <MenuItem Header="Pessoal" IsVisible="False">
          <MenuItem Header="Banco de Horas" Command="{Binding BancoHorasCommand}"/>
        </MenuItem>
        <Separator/>
        <MenuItem Header="Módulo Gestão de Pessoas" Command="{Binding ModuloGestaoPessoasCommand}" IsVisible="False"/>
        <Separator/>
        <MenuItem Header="Monitoramento Eletrônico" Command="{Binding MonitoramentoEletronicoCommand}"/>
        <Separator/>
        <MenuItem Header="Web Browser" Command="{Binding WebBrowserCommand}" IsVisible="False"/>
      </MenuItem>

      <MenuItem Header="Configuração">
        <MenuItem Header="Usuário/Funcionário" Command="{Binding FuncionarioCommand}"/>
        <MenuItem Header="Função Funcionário" Command="{Binding FuncaoFuncionarioCommand}"/>
        <MenuItem Header="Unidade Penal" Command="{Binding UnidadePenalCommand}"/>
        <MenuItem Header="Horário do Funcionário" Command="{Binding HorarioFuncionarioCommand}"/>
        <Separator/>
        <MenuItem Header="Perfil de Usuário" Command="{Binding PerfilUsuarioCommand}"/>
        <MenuItem Header="Padrão do Sistema" Command="{Binding PadraoSistemaCommand}"/>
        <Separator/>
        <MenuItem Header="Equipe" Command="{Binding EquipeCommand}"/>
        <MenuItem Header="Posto / Local de Trabalho" Command="{Binding PostoLocalTrabalhoCommand}"/>
        <MenuItem Header="Agente por Equipe" Command="{Binding AgentePorEquipeCommand}"/>
        <Separator/>
        <MenuItem Header="Regra de Visitação" Command="{Binding RegraVisitaçãoCommand}"/>
      </MenuItem>

      <MenuItem Header="Manutenção">
        <MenuItem Header="Atualizar Meus Dados" Command="{Binding AtualizarMeusDadosCommand}"/>
        <MenuItem Header="Trocar Senha" Command="{Binding TrocarSenhaCommand}"/>
        <Separator/>
        <MenuItem Header="Mensagem do Banco de Dados" Command="{Binding MensagemBancoDadosCommand}"/>
        <MenuItem Header="WebCam" Command="{Binding WebCamCommand}" IsVisible="False"/>
        <Separator/>
        <MenuItem Header="Copiar um arquivo..." Command="{Binding CopiarArquivoCommand}"/>
        <Separator/>
        <MenuItem Header="Consulta PROCED" Command="{Binding ConsultaProcedCommand}"/>
      </MenuItem>

      <MenuItem Header="Agendamento">
        <MenuItem Header="Agenda de Atendimento" Command="{Binding AgendaAtendimentoCommand}"/>
        <Separator/>
        <MenuItem Header="Assunto" Command="{Binding AssuntoCommand}"/>
        <MenuItem Header="Situação" Command="{Binding SituacaoCommand}"/>
        <MenuItem Header="Tipo de Contatos" Command="{Binding TipoContatosCommand}"/>
      </MenuItem>

      <MenuItem Header="Sobre">
        <MenuItem Header="Informações" Command="{Binding SobreCommand}"/>
        <Separator/>
        <MenuItem Header="Muda Skin" Command="{Binding MudaSkinCommand}"/>
        <Separator/>
        <MenuItem Header="Manual" Command="{Binding ManualCommand}"/>
        <MenuItem Header="Atribuição por Setores" Command="{Binding AtribuicaoSetoresCommand}"/>
      </MenuItem>

      <MenuItem Header="Sair" Click="SairMenuItem_Click"/>
    </Menu>

    <!-- Cabeçalho (PanelCabecalho no DFM: 1163×147 com Image2 de fundo) -->
    <Border DockPanel.Dock="Top" Background="#FFFFFF" Height="56" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1">
      <TextBlock Text="{Binding StatusMessage}"
                 FontSize="22" FontWeight="Bold" Foreground="#2B3A4A"
                 VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Border>

    <!-- Conteúdo Principal com TabControl -->
    <Grid>
      <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="4">

        <!-- TAB PRINCIPAL -->
        <TabItem Header="Principal">
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Linha 1: 3 colunas de botões -->
            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- Coluna esquerda -->
              <StackPanel Grid.Column="0" Spacing="8" Margin="4">
                <Button Content="Confere" Height="70" Classes="menuItem" HorizontalAlignment="Stretch"
                        Command="{Binding BtnConfereCommand}" Foreground="#2B3A4A" FontSize="14"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Button Content="Agenda de Atendimento" Height="70" Classes="menuItem" HorizontalAlignment="Stretch"
                        Command="{Binding BtnAgendaAtendimentoCommand}" Foreground="#2B3A4A" FontSize="14"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Button Content="Requerimentos" Height="70" Classes="menuItem" HorizontalAlignment="Stretch"
                        Command="{Binding BtnRequerimentosCommand}" Foreground="#2B3A4A" FontSize="14"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
              </StackPanel>

              <!-- Coluna central -->
              <StackPanel Grid.Column="1" Spacing="8" Margin="4">
                <Button Content="Ocorrências Administrativas" Height="70" Classes="menuItem" HorizontalAlignment="Stretch"
                        Command="{Binding BtnOcorrenciaCommand}" Foreground="#2B3A4A" FontSize="14"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
              </StackPanel>

              <!-- Coluna direita -->
              <StackPanel Grid.Column="2" Spacing="8" Margin="4">
                <Button Content="Relatórios" Height="70" Classes="menuItem" HorizontalAlignment="Stretch"
                        Command="{Binding BtnRelatorioCommand}" Foreground="#2B3A4A" FontSize="14"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Button Content="Consulta" Height="70" Classes="menuItem" HorizontalAlignment="Stretch"
                        Command="{Binding BtnConsultaGeralCommand}" Foreground="#2B3A4A" FontSize="14"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Button Content="Histórico / Ficha Disciplinar" Height="70" Classes="menuItem" HorizontalAlignment="Stretch"
                        Command="{Binding BtnHistoricoFichaDisciplinarCommand}" Foreground="#2B3A4A" FontSize="14"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
              </StackPanel>
            </Grid>

            <!-- Linha 2: ComboBox Unidade Penal -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,12,0,8" Spacing="8">
              <TextBlock Text="Unidade Penal:" VerticalAlignment="Center" Foreground="#2B3A4A"
                         FontSize="11"/>
              <ComboBox x:Name="ComboUp" Width="300" Height="22" FontSize="11"
                        PlaceholderText="Selecione...">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="models:UnidadePenal">
                    <TextBlock Text="{Binding NomeUp}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>

            <!-- Linha 3: Painéis de preview (frxPreview no DFM) -->
            <Grid Grid.Row="2" Margin="4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- Painel preview esquerdo (pnl1 no DFM) -->
              <Border Grid.Column="0" Background="#F4F6F8" BorderBrush="Gray" BorderThickness="1"
                      Margin="2" Padding="1">
                <Grid>
                  <TextBlock Text="[Preview de Relatório]"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="Gray" FontSize="11" FontStyle="Italic"/>
                  <!-- Outline tree placeholder -->
                  <StackPanel VerticalAlignment="Bottom" Margin="4">
                    <TextBlock Text="Outline" FontSize="9" Foreground="DarkGray"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Painel preview direito (Panel1 no DFM) -->
              <Border Grid.Column="1" Background="#F4F6F8" BorderBrush="Gray" BorderThickness="1"
                      Margin="2" Padding="1">
                <Grid>
                  <TextBlock Text="[Preview de Relatório]"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="Gray" FontSize="11" FontStyle="Italic"/>
                  <StackPanel VerticalAlignment="Bottom" Margin="4">
                    <TextBlock Text="Outline" FontSize="9" Foreground="DarkGray"/>
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>

            <!-- Linha 4: Rodapé com informações (fundo preto, texto lime) -->
            <Grid Grid.Row="3" VerticalAlignment="Bottom" Margin="4,8,4,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- Data/Hora (LabelDATA_HORA no DFM) -->
              <Border Grid.Column="0" Background="#212529" Padding="6" Margin="2"
                      Height="36">
                <TextBlock Text="{Binding DataHora}" Foreground="#20C997"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16"/>
              </Border>

              <!-- Database info (LabelDatabase no DFM) -->
              <Border Grid.Column="1" Background="#212529" Padding="6" Margin="2"
                      Height="36">
                <TextBlock Text="{Binding DatabaseInfo}" Foreground="#20C997"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12"/>
              </Border>

              <!-- Login info (LabelLOGIN no DFM) -->
              <Border Grid.Column="2" Background="#212529" Padding="6" Margin="2"
                      Height="36">
                <TextBlock Text="{Binding LoginInfo}" Foreground="#20C997"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12"/>
              </Border>
            </Grid>
          </Grid>
        </TabItem>

        <!-- TAB SETORES -->
        <TabItem Header="Setores">
          <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Coluna 1: Saúde + Outros -->
            <Button Grid.Column="0" Grid.Row="0" Content="Clínica Médica" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding ClinicaMedicaCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="0" Grid.Row="1" Content="Disciplina" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding DisciplinaCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="0" Grid.Row="2" Content="Educação" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding EducacaoCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="0" Grid.Row="3" Content="Enfermagem" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding EnfermagemCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="0" Grid.Row="4" Content="Farmácia" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding FarmaciaCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>

            <!-- Coluna 2: Jurídico + Reabilitação -->
            <Button Grid.Column="1" Grid.Row="0" Content="Jurídico" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding JuridicoCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Grid.Row="1" Content="Odontologia" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding OdontologiaCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Grid.Row="2" Content="Pedagogia" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding PedagogiaCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Grid.Row="3" Content="Psicologia" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding PsicologiaCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Grid.Row="4" Content="Psicossocial" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding PsicossocialCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>

            <!-- Coluna 3: Psiquiatria + Trabalho -->
            <Button Grid.Column="2" Grid.Row="0" Content="Psiquiatria" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding PsiquiatriaCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Grid.Row="1" Content="Saúde" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding SaudeCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Grid.Row="2" Content="Serviço Social" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding ServicoSocialCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Grid.Row="3" Content="Terapia Ocupacional" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding TerapiaOcupacionalCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Grid.Row="4" Content="Trabalho" Height="60" Classes="menuItem" HorizontalAlignment="Stretch"
                    Margin="4" Command="{Binding TrabalhoCommand}" Foreground="#2B3A4A" FontSize="13"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
          </Grid>
        </TabItem>

        <!-- TAB PROCEDIMENTOS -->
        <TabItem Header="Procedimentos">
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar (ToolBar1 no DFM) -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
              <Button Content="Agendar Procedimentos" Command="{Binding AgendarProcedimentosCommand}"
                      Padding="10,4" FontSize="11" Margin="0,0,4,0"/>
              <TextBlock Text="|" VerticalAlignment="Center" Foreground="Gray" Margin="4,0"/>
              <Button Content="Configurar Procedimentos" Command="{Binding ConfigurarProcedimentosCommand}"
                      Padding="10,4" FontSize="11" Margin="4,0"/>
              <Button Content="Configurar Ocorrências" Command="{Binding ConfigurarOcorrenciasCommand}"
                      Padding="10,4" FontSize="11" Margin="4,0"/>
              <TextBlock Text="|" VerticalAlignment="Center" Foreground="Gray" Margin="4,0"/>
              <Button Content="Atualizar" Command="{Binding AtualizarProcedimentosCommand}"
                      Padding="10,4" FontSize="11" Margin="4,0"/>
              <Button Content="Posto de Trabalho" Command="{Binding PostoTrabalhoCommand}"
                      Padding="10,4" FontSize="11" Margin="4,0"/>
            </StackPanel>

            <!-- Filtros (RadioGroups no DFM) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
              <TextBlock Text="Período:" VerticalAlignment="Center" FontSize="11" Foreground="#2B3A4A" Margin="0,0,8,0"/>
              <RadioButton Content="Últimos 7 dias" IsChecked="True" FontSize="11" Margin="4,0"/>
              <RadioButton Content="Ontem" FontSize="11" Margin="4,0"/>
              <RadioButton Content="Hoje" FontSize="11" Margin="4,0"/>
              <RadioButton Content="Amanhã" FontSize="11" Margin="4,0"/>
              <RadioButton Content="Próximos 7 dias" FontSize="11" Margin="4,0"/>
              <RadioButton Content="Todos" FontSize="11" Margin="4,0"/>
              <TextBlock Text="|" VerticalAlignment="Center" Foreground="Gray" Margin="8,0"/>
              <RadioButton Content="Ativo/Aberto" IsChecked="True" FontSize="11" Margin="4,0"/>
              <RadioButton Content="Arquivado/Encerrado" FontSize="11" Margin="4,0"/>
            </StackPanel>

            <!-- Área de preview (frxPreview3 no DFM) -->
            <Border Grid.Row="2" Background="#F4F6F8" BorderBrush="Gray" BorderThickness="1">
              <TextBlock Text="[Área de visualização de procedimentos]"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="Gray" FontSize="14" FontStyle="Italic"/>
            </Border>
          </Grid>
        </TabItem>

        <!-- TAB ESCALA DE PLANTÃO -->
        <TabItem Header="Escala de Plantão">
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Controles superiores (Panel3 no DFM) -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6"
                       VerticalAlignment="Center">
              <TextBlock Text="Dia da Escala:" VerticalAlignment="Center" FontSize="11" Margin="0,0,8,0"/>
              <DatePicker Height="22" Margin="0,0,8,0"/>
              <Button Content="Atualizar" Command="{Binding AtualizarEscalaDiaCommand}"
                      Padding="10,4" FontSize="11" Margin="0,0,8,0"/>
              <Button Content="Iniciar Nova Escala" Command="{Binding IniciarNovaEscalaCommand}"
                      Padding="10,4" FontSize="11" Margin="0,0,8,0"/>
              <Button Content="Imprimir Escala" Command="{Binding ImprimirEscalaCommand}"
                      Padding="10,4" FontSize="11" Margin="0,0,8,0"/>
              <Button Content="Apagar Escala" Command="{Binding ApagarEscalaCommand}"
                      Padding="10,4" FontSize="11"/>
            </StackPanel>

            <!-- Navegação + Equipe -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6"
                       VerticalAlignment="Center">
              <TextBlock Text="◀ ▶" VerticalAlignment="Center" FontSize="14" Foreground="#2B3A4A"
                         ToolTip.Tip="Navegação de registros" Margin="0,0,12,0"/>
              <TextBlock Text="Equipe:" VerticalAlignment="Center" FontSize="11" Margin="0,0,8,0"/>
              <ComboBox Width="220" PlaceholderText="Selecione a equipe..." Height="22" FontSize="11"/>
            </StackPanel>

            <!-- Grid de dados (DBGridEscalaPlantao no DFM) -->
            <Border Grid.Row="2" Background="#F4F6F8" BorderBrush="Gray" BorderThickness="1">
              <Grid>
                <TextBlock Text="[Grid de Escala de Plantão]"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="Gray" FontSize="14" FontStyle="Italic"/>
                <!-- Cabeçalhos de coluna simulados -->
                <StackPanel VerticalAlignment="Top" Margin="4">
                  <StackPanel Orientation="Horizontal">
                    <Border Background="#FFE0E0E0" Padding="8,2" BorderBrush="Gray" BorderThickness="0.5" Margin="0,0,4,0">
                      <TextBlock Text="Data" FontSize="10" FontWeight="Bold" Width="70"/>
                    </Border>
                    <Border Background="#FFE0E0E0" Padding="8,2" BorderBrush="Gray" BorderThickness="0.5" Margin="0,0,4,0">
                      <TextBlock Text="Equipe" FontSize="10" FontWeight="Bold" Width="90"/>
                    </Border>
                    <Border Background="#FFE0E0E0" Padding="8,2" BorderBrush="Gray" BorderThickness="0.5" Margin="0,0,4,0">
                      <TextBlock Text="Funcionário" FontSize="10" FontWeight="Bold" Width="140"/>
                    </Border>
                    <Border Background="#FFE0E0E0" Padding="8,2" BorderBrush="Gray" BorderThickness="0.5" Margin="0,0,4,0">
                      <TextBlock Text="Posto" FontSize="10" FontWeight="Bold" Width="140"/>
                    </Border>
                    <Border Background="#FFE0E0E0" Padding="8,2" BorderBrush="Gray" BorderThickness="0.5" Margin="0,0,4,0">
                      <TextBlock Text="Observações" FontSize="10" FontWeight="Bold" Width="180"/>
                    </Border>
                    <Border Background="#FFE0E0E0" Padding="8,2" BorderBrush="Gray" BorderThickness="0.5" Margin="0,0,4,0">
                      <TextBlock Text="Início" FontSize="10" FontWeight="Bold" Width="45"/>
                    </Border>
                    <Border Background="#FFE0E0E0" Padding="8,2" BorderBrush="Gray" BorderThickness="0.5" Margin="0,0,4,0">
                      <TextBlock Text="Fim" FontSize="10" FontWeight="Bold" Width="45"/>
                    </Border>
                    <Border Background="#FFE0E0E0" Padding="8,2" BorderBrush="Gray" BorderThickness="0.5">
                      <TextBlock Text="Substituto" FontSize="10" FontWeight="Bold" Width="80"/>
                    </Border>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <!-- TAB CAIXA DE MENSAGEM -->
        <TabItem Header="Caixa de Mensagem">
          <Grid Margin="8">
            <TextBlock Text="Caixa de Mensagem"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="14" FontStyle="Italic"/>
          </Grid>
        </TabItem>

        <!-- TAB IDENTIFICAÇÃO -->
        <TabItem Header="Identificação">
          <Grid Margin="16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Coluna esquerda: Foto + dados básicos -->
            <StackPanel Grid.Column="0" Spacing="0">
              <!-- Foto placeholder (DBImage no DFM) -->
              <Border Width="150" Height="170" BorderBrush="Gray" BorderThickness="1"
                      Background="#FFF5F5F5" Margin="0,0,0,8">
                <TextBlock Text="[Foto]" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="Gray" FontSize="11"/>
              </Border>

              <!-- Campos de identificação -->
              <StackPanel Spacing="4" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="ID:" Width="70" Foreground="#2B3A4A" FontWeight="Bold" FontSize="11"/>
                  <TextBlock Text="---" FontWeight="Bold" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Nome:" Width="70" Foreground="#2B3A4A" FontWeight="Bold" FontSize="11"/>
                  <TextBlock Text="---" FontWeight="Bold" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="Matrícula:" Width="70" Foreground="#2B3A4A" FontWeight="Bold" FontSize="11"/>
                  <TextBlock Text="---" FontWeight="Bold" FontSize="11"/>
                </StackPanel>
              </StackPanel>
            </StackPanel>

            <!-- Coluna direita: Tabs internas -->
            <TabControl Grid.Column="1" Margin="16,0,0,0">
              <TabItem Header="Logs de Acesso">
                <Border Background="#F4F6F8" BorderBrush="Gray" BorderThickness="1" Margin="2">
                  <TextBlock Text="Logs de acesso do funcionário"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="Gray" FontSize="12" FontStyle="Italic"/>
                </Border>
              </TabItem>
              <TabItem Header="Inteligência" IsVisible="False">
                <TextBox AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True"
                         Text="Informações de inteligência..." FontSize="11"/>
              </TabItem>
            </TabControl>
          </Grid>
        </TabItem>

      </TabControl>
    </Grid>
  </DockPanel>
</Window>
