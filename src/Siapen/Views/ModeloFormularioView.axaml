<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Siapen.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
        x:Class="Siapen.Views.ModeloFormularioView"
        x:DataType="vm:ModeloFormularioViewModel"
        Title="{Binding Titulo}"
        WindowStartupLocation="CenterOwner"
        Width="600" Height="400"
        Background="#F4F6F8">

  <Design.DataContext>
    <vm:ModeloFormularioViewModel/>
  </Design.DataContext>

  <DockPanel>
    <!-- PainelTitulo -->
    <Border DockPanel.Dock="Top" Background="#FFF8F0E0" Height="48" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1">
      <DockPanel>
        <Border Width="35" Height="35" Margin="12,0,8,0" Background="#E9ECEF" CornerRadius="4"
                VerticalAlignment="Center">
          <TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <TextBlock Text="{Binding Titulo}" FontSize="16" FontWeight="Bold" Foreground="#2B3A4A"
                   VerticalAlignment="Center"/>
      </DockPanel>
    </Border>

    <!-- PanelGeral -->
    <Border DockPanel.Dock="Bottom" Background="#F4F6F8" Padding="8">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="Confirmar" Command="{Binding ConfirmarCommand}" Width="100" Height="32" FontSize="13"/>
        <Button Content="Cancelar" Command="{Binding CancelarCommand}" Width="100" Height="32" FontSize="13"/>
      </StackPanel>
    </Border>

    <!-- Conteúdo principal -->
    <ContentControl x:Name="ContentArea" Margin="12" VerticalContentAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"/>
  </DockPanel>
</Window>
