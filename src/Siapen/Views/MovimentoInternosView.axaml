<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Siapen.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="500"
        x:Class="Siapen.Views.MovimentoInternosView"
        x:DataType="vm:MovimentoInternosViewModel"
        Title="SIAPEN - Movimentação de Internos(as)"
        WindowStartupLocation="CenterScreen"
        Width="900" Height="500"
        Background="#F4F6F8">

  <Design.DataContext>
    <vm:MovimentoInternosViewModel/>
  </Design.DataContext>

  <DockPanel>
    <!-- Top toolbar -->
    <Border DockPanel.Dock="Top" Background="#2B3A4A">
      <DockPanel>
        <!-- Buttons bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#2B3A4A" Spacing="2" Margin="3,1">
          <Button Content="Novo" Command="{Binding NovoCommand}"
                  Height="26" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#198754"
                  IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
          <Button Content="Editar" Command="{Binding EditarCommand}"
                  Height="26" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#0D6EFD"
                  IsEnabled="{Binding Modo, Converter={x:Static vm:CadastroModoConverters.IsNavegando}}"/>
          <Button Content="Cancelar" Command="{Binding CancelarCommand}"
                  Height="26" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#6C757D"
                  IsEnabled="{Binding CamposHabilitados}"/>
          <Button Content="Salvar" Command="{Binding SalvarCommand}"
                  Height="26" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#0D6EFD"
                  IsEnabled="{Binding CamposHabilitados}"/>
          <Button Content="Fechar" Click="Fechar_Click"
                  Height="26" FontSize="11" FontWeight="Bold"
                  Foreground="White" Background="#DC3545"/>
        </StackPanel>

        <!-- Search bar -->
        <Border Background="#F8F9FA" Padding="4,2" BorderBrush="#DEE2E6" BorderThickness="0,1">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto">
            <TextBlock Grid.Column="0" Text="Localizar:" VerticalAlignment="Center"
                       Margin="0,0,4,0" Foreground="#2B3A4A" FontSize="10"/>
            <TextBox Grid.Column="1" Text="{Binding SearchText}"
                     PlaceholderText="Digite para filtrar..."
                     FontSize="11" Height="22"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="3" Margin="4,0,0,0">
              <RadioButton Content="Ativo" IsChecked="{Binding FiltroStatusIndex, Converter={x:Static vm:IndexToBoolConverter.Instance}, ConverterParameter=0}"
                           GroupName="Status" FontSize="10"/>
              <RadioButton Content="Inativo" IsChecked="{Binding FiltroStatusIndex, Converter={x:Static vm:IndexToBoolConverter.Instance}, ConverterParameter=1}"
                           GroupName="Status" FontSize="10"/>
            </StackPanel>
            <CheckBox Grid.Column="3" Content="Fonética" IsChecked="{Binding UsarSoundex}"
                      Margin="4,0,0,0" FontSize="10"/>
          </Grid>
        </Border>
      </DockPanel>
    </Border>

    <!-- Main content -->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Cadastro TabControl -->
      <TabControl Grid.Row="0" TabStripPlacement="Top" IsEnabled="{Binding CamposHabilitados}">
        <TabItem Header="Cadastro">
          <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="1" Padding="4" MinHeight="155">
            <Grid>
              <!-- Top fields: Nome, Nº Roupa, CI, Data Entrada, Status, Em Trânsito -->
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <!-- Row 0: Nome, Nº Roupa, CI, Data Entrada, Status, Em Trânsito -->
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Margin="0,0,3,0">
                  <TextBlock Text="Nome" FontSize="10" Foreground="#666"/>
                  <TextBox Text="{Binding NomeInterno}" FontSize="12" FontWeight="Bold"
                           PlaceholderText="Nome do Interno" Height="24"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Width="90" Margin="3,0">
                  <TextBlock Text="Nº Roupa" FontSize="10" Foreground="#666"/>
                  <TextBox Text="{Binding NumeroRoupa}" FontSize="11" Height="24"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Width="90" Margin="3,0">
                  <TextBlock Text="CI/OF. MOV." FontSize="10" Foreground="#666"/>
                  <TextBox Text="{Binding CiOfMovimento}" FontSize="11" Height="24"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Width="85" Margin="3,0">
                  <TextBlock Text="Dt. Entrada" FontSize="10" Foreground="#666"/>
                  <TextBox Text="{Binding DataEntrada}" FontSize="11" PlaceholderText="dd/mm/aaaa" Height="24"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Width="65" Margin="3,0">
                  <TextBlock Text="Status" FontSize="10" Foreground="#666"/>
                  <ComboBox SelectedIndex="{Binding StatusIndex}" FontSize="11" Height="24">
                    <ComboBoxItem Content="Ativo"/>
                    <ComboBoxItem Content="Inativo"/>
                  </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="5" Width="65" Margin="3,0,0,0">
                  <TextBlock Text="Trânsito" FontSize="10" Foreground="#666"/>
                  <ComboBox SelectedItem="{Binding EmTransito}" FontSize="11" Height="24">
                    <ComboBoxItem Content="S"/>
                    <ComboBoxItem Content="N"/>
                  </ComboBox>
                </StackPanel>
              </Grid>

              <!-- Row 1: PageControlDadosInterno (sub-tabs) -->
              <TabControl Grid.Row="1" TabStripPlacement="Top" Margin="0,4,0,0">
                <!-- Aba Dados -->
                <TabItem Header="Dados">
                  <Grid ColumnDefinitions="*,120">
                    <Grid Grid.Column="0" ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                      <!-- Row 0: RGI, Procedência, Vulgo -->
                      <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,3,3">
                        <TextBlock Text="RGI" FontSize="10" Foreground="#666"/>
                        <TextBox Text="{Binding Rgi}" FontSize="11" Height="22"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Grid.Row="0" Margin="3,0,3,3">
                        <TextBlock Text="PROCEDÊNCIA" FontSize="10" Foreground="#666"/>
                        <ComboBox ItemsSource="{Binding Procedencias}"
                                  SelectedItem="{Binding SelectedProcedencia}"
                                  DisplayMemberBinding="{Binding DisplayName}"
                                  FontSize="11" Height="22"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Grid.Row="0" Margin="3,0,0,3">
                        <TextBlock Text="Vulgo" FontSize="10" Foreground="#666"/>
                        <TextBox Text="{Binding Vulgo}" FontSize="11" Height="22"/>
                      </StackPanel>

                      <!-- Row 1: Mãe, Pai -->
                      <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,3,3">
                        <TextBlock Text="Mãe" FontSize="10" Foreground="#666"/>
                        <TextBox Text="{Binding Mae}" FontSize="11" Height="22"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Grid.Row="1" Margin="3,0,0,3">
                        <TextBlock Text="Pai" FontSize="10" Foreground="#666"/>
                        <TextBox Text="{Binding Pai}" FontSize="11" Height="22"/>
                      </StackPanel>

                      <!-- Row 2: Data Setor, Setor Trabalho -->
                      <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,3,3">
                        <TextBlock Text="DATA SETOR" FontSize="10" Foreground="#666"/>
                        <TextBox Text="{Binding DataEntrada}" FontSize="11" PlaceholderText="dd/mm/aaaa" IsEnabled="False" Height="22"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2" Margin="3,0,0,3">
                        <TextBlock Text="SETOR TRABALHO" FontSize="10" Foreground="#666"/>
                        <ComboBox ItemsSource="{Binding SetoresTrabalho}"
                                  SelectedItem="{Binding SelectedSetorTrabalho}"
                                  DisplayMemberBinding="{Binding DisplayName}"
                                  FontSize="11" Height="22"/>
                      </StackPanel>

                      <!-- Row 3: Condição Interno, Sexo -->
                      <StackPanel Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,3,0">
                        <TextBlock Text="Condição do Interno" FontSize="10" Foreground="#666"/>
                        <ComboBox ItemsSource="{Binding CondicoesInterno}"
                                  SelectedItem="{Binding SelectedCondicaoInterno}"
                                  DisplayMemberBinding="{Binding DisplayName}"
                                  FontSize="11" Height="22"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Grid.Row="3" Margin="3,0,0,0">
                        <TextBlock Text="Sexo" FontSize="10" Foreground="#666"/>
                        <ComboBox SelectedIndex="{Binding SexoIndex}" FontSize="11" Height="22">
                          <ComboBoxItem Content="Masculino"/>
                          <ComboBoxItem Content="Feminino"/>
                        </ComboBox>
                      </StackPanel>
                    </Grid>

                    <!-- Foto placeholder -->
                    <Border Grid.Column="1" Background="#EEE" BorderBrush="#CCC" BorderThickness="1"
                            Margin="4,0,0,0" VerticalAlignment="Stretch">
                      <TextBlock Text="Foto" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Foreground="#999" FontSize="11"/>
                    </Border>
                  </Grid>
                </TabItem>

                <!-- Aba Cela -->
                <TabItem Header="Cela">
                  <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                      <TextBlock Text="Pavilhão" FontSize="10" Foreground="#666" Margin="0,0,0,2"/>
                      <ComboBox ItemsSource="{Binding Pavilhoes}"
                                SelectedItem="{Binding SelectedPavilhao}"
                                DisplayMemberBinding="{Binding DisplayName}"
                                FontSize="11" Height="22" Margin="0,0,0,4"/>
                      <TextBlock Text="Galeria" FontSize="10" Foreground="#666" Margin="0,0,0,2"/>
                      <ComboBox ItemsSource="{Binding Galerias}"
                                SelectedItem="{Binding SelectedGaleria}"
                                DisplayMemberBinding="{Binding DisplayName}"
                                FontSize="11" Height="22" Margin="0,0,0,4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                      <TextBlock Text="Solário" FontSize="10" Foreground="#666" Margin="0,0,0,2"/>
                      <ComboBox ItemsSource="{Binding Solarios}"
                                SelectedItem="{Binding SelectedSolario}"
                                DisplayMemberBinding="{Binding DisplayName}"
                                FontSize="11" Height="22" Margin="0,0,0,4"/>
                      <TextBlock Text="Cela" FontSize="10" Foreground="#666" Margin="0,0,0,2"/>
                      <ComboBox ItemsSource="{Binding Celas}"
                                SelectedItem="{Binding SelectedCela}"
                                DisplayMemberBinding="{Binding DisplayName}"
                                FontSize="11" Height="22" Margin="0,0,0,4"/>
                    </StackPanel>
                  </Grid>
                </TabItem>

                <!-- Aba Fotos -->
                <TabItem Header="Fotos">
                  <Border Background="#EEE" BorderBrush="#CCC" BorderThickness="1"
                          HorizontalAlignment="Left" Width="100" Height="90">
                    <TextBlock Text="Foto Perfil" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#999" FontSize="11"/>
                  </Border>
                </TabItem>

                <!-- Aba Saída -->
                <TabItem Header="Saída">
                  <Grid ColumnDefinitions="Auto,Auto,Auto,*" RowDefinitions="Auto,Auto">
                    <StackPanel Grid.Column="0" Grid.Row="0" Width="85" Margin="0,0,4,4">
                      <TextBlock Text="DATA SAÍDA" FontSize="10" Foreground="#666"/>
                      <TextBox Text="{Binding DataSaida}" FontSize="11" PlaceholderText="dd/mm/aaaa" Height="22"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0" Width="130" Margin="4,0,4,4">
                      <TextBlock Text="MOTIVO" FontSize="10" Foreground="#666"/>
                      <ComboBox SelectedItem="{Binding MotivoSaida}" FontSize="11" IsEditable="True" Height="22">
                        <ComboBoxItem Content="Alvará de Soltura"/>
                        <ComboBoxItem Content="Livramento Condicional"/>
                        <ComboBoxItem Content="Saída Temporária"/>
                        <ComboBoxItem Content="Fuga"/>
                        <ComboBoxItem Content="Óbito"/>
                        <ComboBoxItem Content="Transferência"/>
                        <ComboBoxItem Content="Outros"/>
                      </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="0" Width="100" Margin="4,0,0,4">
                      <TextBlock Text="CI/OF SAÍDA" FontSize="10" Foreground="#666"/>
                      <TextBox Text="{Binding CiOfSaida}" FontSize="11" Height="22"/>
                    </StackPanel>
                    <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" Margin="0,0,0,0">
                      <TextBlock Text="DESTINO" FontSize="10" Foreground="#666"/>
                      <ComboBox ItemsSource="{Binding Destinos}"
                                SelectedItem="{Binding SelectedDestino}"
                                DisplayMemberBinding="{Binding DisplayName}"
                                FontSize="11" Height="22"/>
                    </StackPanel>
                  </Grid>
                </TabItem>
              </TabControl>
            </Grid>
          </Border>
        </TabItem>
      </TabControl>

      <!-- Bottom TabControl: Consulta / Movimentação -->
      <TabControl Grid.Row="1" TabStripPlacement="Top">
        <TabItem Header="Consulta">
          <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0">
            <DataGrid ItemsSource="{Binding GridItems}"
                      SelectedItem="{Binding SelectedGridItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="White"
                      RowHeight="20" FontSize="10"
                      x:CompileBindings="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding NomeInterno}" Width="*"/>
                <DataGridTextColumn Header="Sigla" Binding="{Binding Sigla}" Width="70"/>
                <DataGridTextColumn Header="Pavilhão" Binding="{Binding Pavilhao}" Width="90"/>
                <DataGridTextColumn Header="Solário" Binding="{Binding Solario}" Width="70"/>
                <DataGridTextColumn Header="Cela" Binding="{Binding Cela}" Width="50"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="50"/>
                <DataGridTextColumn Header="Trânsito" Binding="{Binding EmTransito}" Width="50"/>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </TabItem>

        <TabItem Header="Movimentação">
          <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0">
            <DataGrid ItemsSource="{Binding MovimentoDataSource}"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0" Background="White"
                      RowHeight="20" FontSize="10"/>
          </Border>
        </TabItem>
      </TabControl>

      <!-- Status bar -->
      <Border Grid.Row="2" Background="#212529" Padding="6,2" Height="22">
        <TextBlock Text="{Binding StatusMessage}" Foreground="#20C997" FontSize="10"/>
      </Border>
    </Grid>
  </DockPanel>
</Window>
